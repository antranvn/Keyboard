<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_keyboard"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="?android:attr/textColorSecondary" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/hapticSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:checked="true"
            android:text="@string/settings_haptic" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/keyPreviewSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:checked="true"
            android:text="@string/settings_key_preview" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/shuffleSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:checked="false"
            android:text="@string/settings_shuffle" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/soundSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:checked="false"
            android:text="@string/settings_sound" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:background="?android:attr/dividerVertical" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_appearance"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="?android:attr/textColorSecondary" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/darkThemeSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/settings_dark_theme" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:background="?android:attr/dividerVertical" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_security"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="?android:attr/textColorSecondary" />

        <RadioGroup
            android:id="@+id/securityGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/levelStrict"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="STRICT" />

            <RadioButton
                android:id="@+id/levelModerate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MODERATE" />

            <RadioButton
                android:id="@+id/levelRelaxed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RELAXED" />
        </RadioGroup>

    </LinearLayout>
</ScrollView>
