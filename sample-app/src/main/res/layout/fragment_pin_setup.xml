<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp">

    <TextView
        android:id="@+id/pinTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="@string/pin_title"
        android:textAppearance="?attr/textAppearanceHeadlineMedium"
        android:textColor="?attr/colorPrimary" />

    <TextView
        android:id="@+id/pinSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/pin_subtitle"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?android:attr/textColorSecondary" />

    <LinearLayout
        android:id="@+id/pinRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:orientation="horizontal">

        <com.securekey.sdk.ui.SecureEditText
            android:id="@+id/pin1"
            style="@style/PinDigit" />

        <com.securekey.sdk.ui.SecureEditText
            android:id="@+id/pin2"
            style="@style/PinDigit" />

        <com.securekey.sdk.ui.SecureEditText
            android:id="@+id/pin3"
            style="@style/PinDigit" />

        <com.securekey.sdk.ui.SecureEditText
            android:id="@+id/pin4"
            style="@style/PinDigit" />
    </LinearLayout>

    <TextView
        android:id="@+id/pinError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?attr/colorError"
        android:visibility="invisible" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/pin_note"
        android:textAppearance="?attr/textAppearanceLabelSmall"
        android:textColor="?android:attr/textColorSecondary" />

</LinearLayout>
